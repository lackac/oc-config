{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },

  "agents": {
    // Main orchestrator for multi-step coordination, delegation, and codebase-wide execution.
    "sisyphus": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "medium",
      "fallback_models": [
        "github-copilot/claude-opus-4.7",
        "openai/gpt-5.3-codex",
        "github-copilot/claude-sonnet-4.6",
        "opencode/claude-sonnet-4-6",
        "github-copilot/claude-haiku-4.5"
      ],
      "ultrawork": { "variant": "xhigh" }
    },
    // Strategic planner for interview-style planning and high-level architecture shaping.
    "prometheus": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "high",
      "fallback_models": [
        "github-copilot/claude-opus-4.7",
        "openai/gpt-5.3-codex",
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    // Plan gap analyzer for finding missing steps and weak assumptions before execution.
    "metis": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "high",
      "fallback_models": [
        "github-copilot/claude-opus-4.7",
        "openai/gpt-5.3-codex",
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    // Todo orchestrator for sequencing task items and driving execution across steps.
    "atlas": {
      "model": "openai/gpt-5.5-fast",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "openai/gpt-5.3-codex",
        "opencode/claude-sonnet-4-6",
        "github-copilot/claude-haiku-4.5"
      ]
    },

    // Autonomous deep worker for long, independent coding sessions across complex codebases.
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "openai/gpt-5.5",
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    // Read-only architecture consultant for high-stakes design and debugging judgment.
    "oracle": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "high",
      "fallback_models": [
        "github-copilot/gpt-5.2",
        "github-copilot/gpt-5.3-codex",
        "openai/gpt-5.3-codex",
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    // Ruthless reviewer for plan review, QA thinking, and critical verification passes.
    "momus": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "openai/gpt-5.3-codex",
        "github-copilot/claude-sonnet-4.6"
      ]
    },

    // Fast codebase grep runner for parallel repo search and pattern discovery.
    "explore": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        "openai/gpt-5.5-fast",
        "github-copilot/gpt-5-mini",
        "github-copilot/claude-haiku-4.5",
        "opencode/gpt-5.4-nano"
      ]
    },
    // Docs and external code search agent for pulling references from outside the repo.
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "github-copilot/claude-haiku-4.5",
        "opencode/gpt-5.4-nano"
      ]
    },

    // Vision agent for screenshots, image analysis, and other multimodal inspection tasks.
    "multimodal-looker": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "medium",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview",
        "github-copilot/gemini-3-flash-preview",
        "openai/gpt-5.3-codex"
      ]
    }
  },

  "categories": {
    "quick": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        "openai/gpt-5.5-fast",
        "github-copilot/gpt-5-mini",
        "github-copilot/claude-haiku-4.5",
        "opencode/gpt-5.4-nano"
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "github-copilot/claude-haiku-4.5"
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "high",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "openai/gpt-5.3-codex"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "openai/gpt-5.3-codex",
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5-fast",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "github-copilot/claude-opus-4.7",
        "openai/gpt-5.3-codex",
        "github-copilot/gpt-5.3-codex"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.5-fast",
      "fallback_models": [
        "github-copilot/gpt-5.4",
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.5-fast",
        "github-copilot/claude-opus-4.7",
        "opencode/claude-sonnet-4-6"
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.5-fast",
      "fallback_models": [
        "github-copilot/claude-opus-4.7",
        "openai/gpt-5.2",
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },

    "git": {
      "model": "openai/gpt-5.5-fast",
      "fallback_models": [
        "github-copilot/gpt-5.3-codex",
        "openai/gpt-5.3-codex",
        "opencode/gpt-5.4-nano"
      ],
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, safe operations, and Conventional Commits with concise messages that describe what changed and its intent; avoid rote file-by-file mirroring and generic add/delete/update phrasing."
    }
  },

  "background_task": {
    "providerConcurrency": {
      "openai": 6,
      "github-copilot": 4,
      "opencode": 2
    },
    "modelConcurrency": {
      "openai/gpt-5.5": 4,
      "openai/gpt-5.3-codex": 4,
      "openai/gpt-5.4-mini-fast": 6,
      "openai/gpt-5.5-fast": 6,
      "github-copilot/gpt-5.3-codex": 4,
      "github-copilot/gpt-5-mini": 6,
      "github-copilot/gemini-3.1-pro-preview": 2,
      "github-copilot/gemini-3-flash-preview": 6
    }
  },

  "git_master": {
    "include_co_authored_by": false,
    "commit_footer": false
  },

  "experimental": { "aggressive_truncation": true, "task_system": false },
  "tmux": { "enabled": false }
}
