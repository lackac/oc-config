{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",

  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },

  "agents": {
    // Orchestrators: Sonnet for day-to-day, Opus only where it adds clear value.
    "sisyphus": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "opencode/claude-sonnet-4-6",
        "github-copilot/claude-haiku-4.5"
      ],
      "ultrawork": { "model": "anthropic/claude-opus-4-6", "variant": "max" }
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "openai/gpt-5.2-codex",
        "github-copilot/claude-opus-4.6",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "fallback_models": [
        "github-copilot/claude-opus-4.6",
        "openai/gpt-5.3-codex",
        "openai/gpt-5.2-codex",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "openai/gpt-5.2-codex",
        "github-copilot/claude-sonnet-4.6",
        "opencode/claude-sonnet-4-6",
        "github-copilot/claude-haiku-4.5"
      ]
    },

    // Deep coding and architecture: OpenAI first.
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high",
      "fallback_models": [
        "github-copilot/gpt-5.2-codex",
        "openai/gpt-5.2-codex"
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "reasoningEffort": "high",
      "fallback_models": [
        "github-copilot/gpt-5.2",
        "github-copilot/gpt-5.2-codex",
        "openai/gpt-5.2-codex",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.2",
      "reasoningEffort": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.2-codex",
        "openai/gpt-5.2-codex",
        "anthropic/claude-sonnet-4-6"
      ]
    },

    // Utility agents: cheap/fallback tier, no Grok.
    "explore": {
      "model": "github-copilot/gpt-5.1-codex-mini",
      "fallback_models": [
        "github-copilot/gpt-5-mini",
        "openai/gpt-5.1-codex-mini",
        "github-copilot/claude-haiku-4.5",
        "opencode/gpt-5-nano"
      ]
    },
    "librarian": {
      "model": "github-copilot/gpt-5.1-codex-mini",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "github-copilot/gpt-5-mini",
        "openai/gpt-5.1-codex-mini",
        "opencode/gpt-5-nano"
      ]
    },

    // Visual tasks through Gemini via Copilot.
    "multimodal-looker": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "fallback_models": [
        "github-copilot/gemini-3-pro-preview",
        "github-copilot/gemini-3-flash-preview",
        "openai/gpt-5.2-codex"
      ]
    }
  },

  "categories": {
    "quick": {
      "model": "openai/gpt-5.1-codex-mini",
      "fallback_models": [
        "github-copilot/gpt-5-mini",
        "github-copilot/gpt-5.1-codex-mini",
        "github-copilot/claude-haiku-4.5",
        "opencode/gpt-5-nano"
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.2-codex",
      "reasoningEffort": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.1-codex-mini",
        "github-copilot/claude-haiku-4.5"
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high",
      "fallback_models": [
        "openai/gpt-5.2-codex",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.2-codex",
        "openai/gpt-5.2-codex",
        "anthropic/claude-sonnet-4-6"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "github-copilot/gpt-5.2-codex",
        "openai/gpt-5.2-codex",
        "anthropic/claude-opus-4-6"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.2",
      "fallback_models": [
        "anthropic/claude-sonnet-4-6",
        "github-copilot/gpt-5.2"
      ]
    },
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "fallback_models": [
        "github-copilot/gemini-3-pro-preview",
        "github-copilot/gemini-3-flash-preview",
        "openai/gpt-5.2-codex"
      ]
    },
    "artistry": {
      "model": "github-copilot/gemini-3-pro-preview",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "anthropic/claude-sonnet-4-6",
        "openai/gpt-5.2"
      ]
    },

    "git": {
      "model": "github-copilot/gpt-5.1-codex-mini",
      "fallback_models": [
        "openai/gpt-5.1-codex-mini",
        "github-copilot/gpt-5-mini",
        "opencode/gpt-5-nano"
      ],
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, safe operations, and Conventional Commits with concise messages that describe what changed and its intent; avoid rote file-by-file mirroring and generic add/delete/update phrasing."
    }
  },

  "background_task": {
    "providerConcurrency": {
      "anthropic": 1,
      "openai": 5,
      "github-copilot": 4,
      "opencode": 2
    },
    "modelConcurrency": {
      "anthropic/claude-opus-4-6": 1,
      "anthropic/claude-sonnet-4-6": 2,
      "openai/gpt-5.3-codex": 3,
      "openai/gpt-5.2-codex": 4,
      "openai/gpt-5.1-codex-mini": 8,
      "github-copilot/gpt-5.1-codex-mini": 10,
      "github-copilot/gemini-3.1-pro-preview": 2,
      "github-copilot/gemini-3-flash-preview": 6
    }
  },

  "git_master": {
    "include_co_authored_by": false,
    "commit_footer": false
  },

  "experimental": { "aggressive_truncation": true, "task_system": true },
  "tmux": { "enabled": false }
}
